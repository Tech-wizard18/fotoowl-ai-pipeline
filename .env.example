# Required: Groq API Key (FREE from https://console.groq.com)
GROQ_API_KEY=groq_api_key

# Models (all FREE, unlimited tier)
# Vision: llama-3.2-90b-vision-preview
# Text: llama-3.3-70b-versatile (fastest)
VISION_MODEL=llama-3.2-90b-vision-preview
CREATIVE_MODEL=llama-3.3-70b-versatile
UTILITY_MODEL=llama-3.3-70b-versatile

# Max compile retry attempts
MAX_RETRIES=3
